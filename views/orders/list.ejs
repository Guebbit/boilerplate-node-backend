<!DOCTYPE html>
<html lang="en">
<%- include("../layouts/main-head.ejs"); %>
<body>
<%- include("../layouts/default-header.ejs"); %>
<%- include("../layouts/default-aside.ejs"); %>

<main>
    <section class="orders-search">
        <h1><%= pageMetaTitle || "Orders" %></h1>

        <form class="orders-search__form">
            <div class="orders-search__row">
                <label>
                    Order ID
                    <input type="text" name="id" value="<%= (search && search.id) ? search.id : '' %>" />
                </label>

                <label>
                    Email
                    <input type="text" name="email" value="<%= (search && search.email) ? search.email : '' %>" />
                </label>

                <label>
                    Product ID
                    <input type="text" name="productId" value="<%= (search && search.productId) ? search.productId : '' %>" />
                </label>

                <% if (isAdmin) { %>
                    <label>
                        User ID
                        <input type="text" name="userId" value="<%= (search && search.userId) ? search.userId : '' %>" />
                    </label>
                <% } %>
            </div>

            <button class="btn" type="submit">Search</button>
            <a class="btn" href="/products">Reset</a>

            <!-- csrfToken not needed in a GET request -->
        </form>
    </section>

    <ul class="orders">
        <% (orderList || []).forEach(function(order) { %>
            <li class="orders__item">
                <b>Order - #<%= order._id %></b>

                <% if (isAdmin && (order.UserId || order.userId)) { %>
                    <small>(UserId - #<%= order.UserId || order.userId %>)</small>
                <% } %>

                <span><b>Email</b>: <%= order.email %></span>

                <% if (typeof order.totalItems !== "undefined") { %>
                    <span><b>Total Items</b>: <%= order.totalItems %></span>
                <% } %>

                <% if (typeof order.totalQuantity !== "undefined") { %>
                    <span><b>Total Quantity</b>: <%= order.totalQuantity %></span>
                <% } %>

                <% if (typeof order.totalPrice !== "undefined") { %>
                    <span><b>Total Price</b>: <%= order.totalPrice %></span>
                <% } %>

                <a class="btn" href="/orders/details/<%= order._id %>">Invoice</a>
                <a class="btn" href="/orders/invoice/<%= order._id %>">Download Invoice</a>
            </li>
        <% }); %>
    </ul>

    <% if (orderList && orderList.length === 0) { %>
        <p>No orders found.</p>
    <% } %>

    <hr />

    <!-- keep your existing pagination component -->
    <%- include("../partials/pagination.ejs", { itemsTotal, pageCurrent, pageTotal }); %>
</main>

<%- include("../layouts/default-footer.ejs"); %>
</body>
</html>