<!DOCTYPE html>
<html lang="en">
<%- include("../_layouts/pdf-template-head.ejs"); %>
<body>
<main class="centered">
    <h1>The order has been confirmed</h1>
    <ul>
        <% order.OrderItems.forEach(function(item) { %>
            <li>
                <%= item.Product.title %> - <%= item.quantity %> - $<%= item.Product.price %>
            </li>
        <% }); %>
    </ul>
</main>
</body>
</html>