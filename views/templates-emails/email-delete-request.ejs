<!DOCTYPE html>
<html lang="en">
<%- include("../layouts/email-template-head.ejs"); %>
<body>
    <main class="centered">
        <h1>Hello, <%= name %>!</h1>
        <p>We received a request to permanently delete your account.</p>
        <p>Click this <a href="<%= process.env.NODE_URL + 'account/delete/' + token %>">link</a> to confirm account deletion.</p>
        <p>If you did not request this, you can safely ignore this email.</p>
    </main>
    <%- include("../layouts/default-footer.ejs"); %>
</body>
</html>
