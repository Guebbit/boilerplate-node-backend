<!DOCTYPE html>
<html lang="en">
<%- include("../layouts/main-head.ejs"); %>
<body>
<%- include("../layouts/default-header.ejs"); %>
<%- include("../layouts/default-aside.ejs"); %>

<main>
    <h2 class="centered"><%= pageMetaTitle || "All Users" %></h2>

    <section class="users-search centered" style="margin: 20px 0;">
        <form style="max-width: 900px; margin: 0 auto;">
            <div style="display:flex; gap:12px; flex-wrap:wrap; justify-content:center; align-items:flex-end;">
                <label>
                    Text
                    <input
                            type="text"
                            name="text"
                            value="<%= (search && search.text) ? search.text : '' %>"
                            placeholder="email or username"
                    />
                </label>

                <label>
                    User ID
                    <input
                            type="text"
                            name="id"
                            value="<%= (search && search.id) ? search.id : '' %>"
                            placeholder="optional"
                    />
                </label>

                <label>
                    Email
                    <input
                            type="text"
                            name="email"
                            value="<%= (search && search.email) ? search.email : '' %>"
                            placeholder="optional"
                    />
                </label>

                <label>
                    Username
                    <input
                            type="text"
                            name="username"
                            value="<%= (search && search.username) ? search.username : '' %>"
                            placeholder="optional"
                    />
                </label>

                <label>
                    Active
                    <select name="active">
                        <option value="" <%= (!search || search.active === undefined || search.active === '') ? 'selected' : '' %>>All</option>
                        <option value="true" <%= (search && search.active === 'true') ? 'selected' : '' %>>Active only</option>
                        <option value="false" <%= (search && search.active === 'false') ? 'selected' : '' %>>Deleted only</option>
                    </select>
                </label>

                <button class="btn" type="submit">Search</button>
                <a class="btn" href="/users">Reset</a>

                <!-- csrfToken not needed in a GET request -->
            </div>
        </form>
    </section>

    <div class="grid">
        <% userList.forEach(function(user) { %>
            <article class="card">
                <header class="card__header">
                    <h1><%= user.username %></h1>
                </header>
                <% if (user.imageUrl) { %>
                    <div class="card__image">
                        <img src="<%= user.imageUrl %>" alt="<%= user.username %>">
                    </div>
                <% } %>
                <div class="card__content centered">
                    <p><strong>Email:</strong> <%= user.email %></p>
                    <% if (user.admin) { %>
                        <p><strong>ADMIN</strong></p>
                    <% } %>
                    <% if (user.deletedAt) { %>
                        <h3><b>SOFT DELETED</b></h3>
                    <% } %>
                </div>
                <div class="card__actions">
                    <a href="/users/details/<%= user._id %>" class="btn">Details</a>
                    <a href="/users/edit/<%= user._id %>" class="btn">Edit</a>
                    <form action="/users/delete" method="post">
                        <% if (user.deletedAt) { %>
                            <button class="btn" type="submit">Un-delete</button>
                        <% } else { %>
                            <button class="btn" type="submit">Delete</button>
                        <% } %>
                        <input type="hidden" name="id" value="<%= user._id %>">
                        <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
                    </form>
                    <form action="/users/delete" method="post">
                        <button class="btn" type="submit">HARD Delete</button>
                        <input type="hidden" name="id" value="<%= user._id %>">
                        <input type="hidden" name="hardDelete" value="true">
                        <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
                    </form>
                </div>
            </article>
        <% }); %>
    </div>

    <hr />

    <!-- Pagination -->
    <div class="pagination centered">
        <% if(pageCurrent !== 1){ %>
            <a href="/users/1">First</a>
            <a href="/users/<%= pageCurrent - 1 %>">Prev</a>
        <% } %>
        <% for(let i = 1; i <= pageTotal; i++) { %>
            <a class="<%= pageCurrent === i ? 'active' : '' %>" href="/users/<%= i %>"><%= i %></a>
        <% } %>
        <% if(pageCurrent < pageTotal){ %>
            <a href="/users/<%= pageCurrent + 1 %>">Next</a>
            <a href="/users/<%= pageTotal %>">Last</a>
        <% } %>
    </div>

    <hr />

    <!-- keep your existing pagination component -->
    <%- include("../partials/pagination.ejs", { itemsTotal, pageCurrent, pageTotal }); %>

    <hr />

    <div class="centered">
        <a href="/users/add" class="btn" style="width: 200px">Add new user</a>
    </div>
</main>

<%- include("../layouts/default-footer.ejs"); %>
</body>
</html>
