<!DOCTYPE html>
<html lang="en">
<%- include("../_layouts/main-head.ejs"); %>
<body>
<%- include("../_layouts/default-header.ejs"); %>
<%- include("../_layouts/default-aside.ejs"); %>
<main class="centered">
    <h1><%= user.username %></h1>
    <hr/>
    <% if (user.imageUrl) { %>
        <div class="image">
            <img src="<%= user.imageUrl %>" alt="<%= user.username %>">
        </div>
    <% } %>
    <p><strong>Email:</strong> <%= user.email %></p>
    <p><strong>Admin:</strong> <%= user.admin ? 'Yes' : 'No' %></p>
    <p><strong>Created:</strong> <%= user.createdAt ? new Date(user.createdAt).toLocaleString() : 'N/A' %></p>
    <p><strong>Updated:</strong> <%= user.updatedAt ? new Date(user.updatedAt).toLocaleString() : 'N/A' %></p>
    <% if (user.deletedAt) { %>
        <h3><b>SOFT DELETED</b> on <%= new Date(user.deletedAt).toLocaleString() %></h3>
    <% } %>
    <hr/>
    <a href="/users/edit/<%= user._id %>" class="btn">Edit</a>
    <form action="/users/delete" method="post" style="display:inline;">
        <% if (user.deletedAt) { %>
            <button class="btn" type="submit">Un-delete</button>
        <% } else { %>
            <button class="btn" type="submit">Delete</button>
        <% } %>
        <input type="hidden" name="id" value="<%= user._id %>">
        <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
    </form>
    <form action="/users/delete" method="post" style="display:inline;">
        <button class="btn" type="submit">HARD Delete</button>
        <input type="hidden" name="id" value="<%= user._id %>">
        <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
        <input type="hidden" name="hardDelete" value="true">
    </form>
    <a href="/users" class="btn">Back to list</a>
</main>
<%- include("../_layouts/default-footer.ejs"); %>
</body>
</html>
