{
  "parser": "@typescript-eslint/parser",
  "plugins": [
    "@typescript-eslint",
    "filenames"
  ],
  "extends": [
    "plugin:@typescript-eslint/recommended"
  ],
  "rules": {
    "@typescript-eslint/naming-convention": [
      "error",
      {
        "selector": "variable",
        "format": ["camelCase", "UPPER_CASE"]
      },
      {
        "selector": "interface",
        "format": ["PascalCase"],
        "custom": {
          "regex": "^I[A-Z]",
          "match": true
        }
      }
    ],
    "filenames/match-regex": ["error", "^[a-z-]+$", true]
  },
  "overrides": [
    {
      "files": ["*.d.ts"],
      "rules": {
        "filenames/match-regex": "off"
      }
    }
  ]
}
