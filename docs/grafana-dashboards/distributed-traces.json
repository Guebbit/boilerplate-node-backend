{
  "__inputs": [
    {
      "name": "DS_TEMPO",
      "label": "Tempo",
      "description": "Tempo data source — points to your Grafana Tempo instance.",
      "type": "datasource",
      "pluginId": "tempo",
      "pluginName": "Tempo"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki data source — used for log-to-trace correlation links.",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0" },
    { "type": "panel", "id": "traces", "name": "Traces", "version": "" },
    { "type": "panel", "id": "nodeGraph", "name": "Node Graph", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Distributed traces from Grafana Tempo. Filter by service and trace ID. Click a trace to drill into spans.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "${DS_TEMPO}",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {},
      "targets": [
        {
          "datasource": "${DS_TEMPO}",
          "filters": [
            { "id": "service-name", "operator": "=", "scope": "resource", "tag": "service.name", "value": "$service" }
          ],
          "limit": 20,
          "queryType": "traceqlSearch",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Recent Traces — $service",
      "type": "traces"
    },
    {
      "datasource": "${DS_TEMPO}",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "id": 2,
      "options": {},
      "targets": [
        {
          "datasource": "${DS_TEMPO}",
          "query": "{ resource.service.name = \"$service\" && duration > 500ms }",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Slow Traces (>500ms) — $service",
      "type": "traces"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["traces", "tempo", "opentelemetry"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "api", "value": "api" },
        "hide": 0,
        "includeAll": false,
        "label": "Service",
        "name": "service",
        "options": [{ "selected": true, "text": "api", "value": "api" }],
        "query": "api",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Distributed Traces",
  "uid": "traces-v1",
  "version": 1
}
