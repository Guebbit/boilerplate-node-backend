{
    "name": "boilerplate-node-api-mongodb-mongoose",
    "version": "2.1.0",
    "main": "src/cluster.ts",
    "license": "AGPLv3.0",
    "scripts": {
        "dev": "tsx watch src/cluster.ts",
        "dev:docker": "nodemon --legacy-watch --watch src --ext ts --exec 'tsx src/app.ts'",
        "dev:docker:cluster": "nodemon --legacy-watch --watch src --ext ts --exec 'tsx src/cluster.ts'",
        "start": "tsx src/cluster.ts",
        "debug": "tsx --inspect-brk src/cluster.ts",
        "ts-check": "tsc --noEmit",
        "build-only": "npm run lint",
        "build": "npm run ts-check && npm run build-only",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "lint:openapi": "spectral lint openapi.yaml",
        "lint:openapi:fix": "spectral lint openapi.yaml --format stylish",
        "prettier": "npx prettier .",
        "prettier:fix": "npx prettier . --write",
        "test": "npm run test:unit && npm run test:integration",
        "test:unit": "jest",
        "test:integration": "jest tests/integration --runInBand",
        "test:unit:target": "npx jest tests/path/file.test.ts",
        "test:prism": "kill $(lsof -t -i:4010) 2>/dev/null; npx @stoplight/prism-cli mock openapi.yaml --errors & PRISM_PID=$!; sleep 2; curl -f http://localhost:4010/products; kill $PRISM_PID",
        "setup:mongod": "docker create --name mongo-temp mongo:latest && docker cp mongo-temp:/usr/bin/mongod /tmp/mongod && docker rm mongo-temp",
        "db:migrate": "node --import tsx ./node_modules/migrate-mongo/bin/migrate-mongo.js up -f migrate-mongo-config.ts",
        "db:migrate:down": "node --import tsx ./node_modules/migrate-mongo/bin/migrate-mongo.js down -f migrate-mongo-config.ts",
        "db:migrate:status": "node --import tsx ./node_modules/migrate-mongo/bin/migrate-mongo.js status -f migrate-mongo-config.ts",
        "db:seed": "tsx db/seeds/index.ts",
        "db:seed:reset": "tsx db/seeds/index.ts --reset",
        "kill:win": "cmd \"/C TASKKILL /IM node.exe /F\"",
        "kill:gnu": "pkill -9 node",
        "podman:restart": "podman compose down && podman compose up -d",
        "podman:rebuild": "podman compose down -v && podman compose build --no-cache && podman compose up -d",
        "podman:nuke": "pkill -9 -f 'podman|conmon|runc' 2>/dev/null || true; systemctl --user restart podman",
        "genapi": "rm -rf ./api && openapi-generator-cli generate -i openapi.yaml -g typescript-node -o ./api",
        "update:all": "npx npm-check-updates -u",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "complete": "npm run build && npm run test && npm run lint:fix && npm run prettier:fix",
        "complete:check": "npm run build && npm run test && npm run lint && npm run prettier:check",
        "publish:public": "npm publish --access public"
    },
    "devDependencies": {
        "@stoplight/prism-cli": "^5.14.2",
        "@stoplight/spectral-cli": "^6.15.0",
        "@stoplight/spectral-rulesets": "^1.22.0",
        "@types/bcrypt": "^6.0.0",
        "@types/connect-flash": "^0.0.40",
        "@types/cookie-parser": "^1.4.10",
        "@types/ejs": "^3.1.5",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.18.2",
        "@types/jest": "^30.0.0",
        "@types/mime-types": "^3.0.1",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.5.0",
        "@types/nodemailer": "^7.0.11",
        "@types/request": "^2.48.13",
        "@typescript-eslint/eslint-plugin": "^8.54.0",
        "@typescript-eslint/parser": "^8.56.1",
        "body-parser": "^2.2.2",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-oxlint": "~1.56.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-unicorn": "^63.0.0",
        "globals": "^17.4.0",
        "jest": "^30.3.0",
        "jiti": "^2.6.1",
        "migrate-mongo": "^14.0.7",
        "mongodb-memory-server": "^11.0.1",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.6",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vitepress": "^1.6.4"
    },
    "dependencies": {
        "@openapitools/openapi-generator-cli": "^2.31.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/ws": "^8.18.1",
        "bcrypt": "^6.0.0",
        "connect-flash": "^0.1.1",
        "connect-mongo": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "csrf-sync": "^4.2.1",
        "dotenv": "^17.3.1",
        "ejs": "^5.0.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.1",
        "express-session": "^1.19.0",
        "helmet": "^8.1.0",
        "i18next": "^25.10.9",
        "jsonwebtoken": "^9.0.3",
        "mime-types": "^3.0.2",
        "mongodb": "^7.1.1",
        "mongoose": "^9.3.3",
        "multer": "^2.1.1",
        "nodemailer": "^8.0.4",
        "puppeteer-core": "^24.40.0",
        "redis": "^5.12.1",
        "winston": "^3.19.0",
        "ws": "^8.20.0",
        "zod": "^4.3.6"
    }
}
