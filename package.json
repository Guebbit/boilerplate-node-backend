{
  "name": "boilerplate-node-mvc-sequelize",
  "version": "1.0.0",
  "main": "src/cluster.ts",
  "license": "AGPLv3.0",
  "scripts": {
    "dev": "tsx watch src/cluster.ts",
    "start": "tsx src/cluster.ts",
    "debug": "tsx --inspect-brk src/cluster.ts",
    "ts-check": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:unit:target": "npx jest tests/controllers/authentication.test.ts",
    "build-only": "npm run lint && npm run ts-check",
    "type-check-only": "tsc --noEmit",
    "build": "run-p type-check-only \"build-only {@}\" --",
    "kill:win": "cmd \"/C TASKKILL /IM node.exe /F\"",
    "kill:gnu": "pkill -9 node",
    "pre-publish": "npm run lint && npm run test:unit && npm run build",
    "genapi": "openapi-generator-cli generate -i ./.dev/openapi.yaml -g typescript-axios -o ./src/api",
    "update:all": "npx npm-check-updates -u"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/connect-flash": "^0.0.40",
    "@types/cookie-parser": "^1.4.10",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.2",
    "@types/nodemailer": "^7.0.9",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "body-parser": "^2.2.2",
    "eslint": "^9.39.2",
    "eslint-plugin-oxlint": "~1.43.0",
    "eslint-plugin-unicorn": "^62.0.0",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "mysql2": "^3.16.3",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@openapitools/openapi-generator-cli": "^2.28.2",
    "@types/mime-types": "^3.0.1",
    "bcrypt": "^6.0.0",
    "connect-flash": "^0.1.1",
    "connect-mongodb-session": "^5.0.0",
    "connect-session-sequelize": "^8.0.5",
    "cookie-parser": "^1.4.7",
    "csrf-sync": "^4.2.1",
    "dotenv": "^17.2.4",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "i18next": "^25.8.4",
    "jsonwebtoken": "^9.0.3",
    "mime-types": "^3.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "puppeteer-core": "^24.37.2",
    "sequelize": "^6.37.7",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}
