{
    "name": "boilerplate-node-api-mongodb-mongoose",
    "version": "2.1.0",
    "main": "src/cluster.ts",
    "license": "AGPLv3.0",
    "scripts": {
        "dev": "tsx watch src/cluster.ts",
        "dev:docker": "nodemon --legacy-watch --watch src --ext ts --exec 'tsx src/app.ts'",
        "dev:docker:cluster": "nodemon --legacy-watch --watch src --ext ts --exec 'tsx src/cluster.ts'",
        "start": "tsx src/cluster.ts",
        "debug": "tsx --inspect-brk src/cluster.ts",
        "ts-check": "tsc --noEmit",
        "build-only": "npm run lint",
        "build": "npm run ts-check && npm run build-only",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "lint:openapi": "spectral lint openapi.yaml",
        "lint:openapi:fix": "spectral lint openapi.yaml --format stylish",
        "lint:asyncapi": "npx @asyncapi/cli validate asyncapi.yaml",
        "prettier": "npx prettier .",
        "prettier:check": "npx prettier . --check",
        "prettier:fix": "npx prettier . --write",
        "test": "npm run test:unit && npm run test:integration",
        "test:unit": "jest",
        "test:integration": "jest tests/integration --runInBand",
        "test:unit:target": "npx jest tests/path/file.test.ts",
        "test:prism": "kill $(lsof -t -i:4010) 2>/dev/null; npx @stoplight/prism-cli mock openapi.yaml --errors & PRISM_PID=$!; sleep 2; curl -f http://localhost:4010/products; kill $PRISM_PID",
        "setup:mongod": "docker create --name mongo-temp mongo:latest && docker cp mongo-temp:/usr/bin/mongod /tmp/mongod && docker rm mongo-temp",
        "db:migrate:up": "migrate-mongo up",
        "db:migrate:down": "migrate-mongo down",
        "db:migrate:status": "migrate-mongo status",
        "db:seed": "tsx db/seeds/index.ts",
        "db:seed:reset": "tsx db/seeds/index.ts --reset",
        "kill:win": "cmd \"/C TASKKILL /IM node.exe /F\"",
        "kill:gnu": "pkill -9 node",
        "podman:restart": "podman compose down && podman compose up -d",
        "podman:rebuild": "podman compose down -v && podman compose build --no-cache && podman compose up -d",
        "podman:nuke": "pkill -9 -f 'podman|conmon|runc' 2>/dev/null || true; systemctl --user restart podman",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "docs:asyncapi": "asyncapi start studio asyncapi.yaml",
        "genapi": "rm -rf ./api && orval --config orval.config.ts",
        "genasyncapi": "tsx scripts/gen-asyncapi-types.ts",
        "update:all": "npm-check-updates -u",
        "complete": "npm run build && npm run test && npm run lint:fix && npm run prettier:fix",
        "complete:check": "npm run build && npm run test && npm run lint && npm run prettier:check",
        "publish:public": "npm publish --access public"
    },
    "devDependencies": {
        "@asyncapi/cli": "^6.0.2",
        "@asyncapi/modelina": "^5.10.1",
        "@commitlint/cli": "^21.2.1",
        "@commitlint/config-conventional": "^21.2.0",
        "@stoplight/prism-cli": "^5.6.0",
        "@stoplight/spectral-cli": "^6.15.0",
        "@stoplight/spectral-rulesets": "^1.22.0",
        "@types/amqplib": "^0.10.8",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/ejs": "^3.1.5",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/js-yaml": "^4.0.9",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mime-types": "^3.0.1",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.5.0",
        "@types/nodemailer": "^7.0.11",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.54.0",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-oxlint": "~1.56.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-unicorn": "^63.0.0",
        "globals": "^17.4.0",
        "jest": "^30.3.0",
        "jiti": "^2.6.1",
        "js-yaml": "^4.1.1",
        "mermaid": "^11.14.0",
        "migrate-mongo": "^14.0.7",
        "mongodb-memory-server": "^11.0.1",
        "nodemon": "^3.1.14",
        "npm-check-updates": "^22.2.3",
        "orval": "^8.17.0",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.6",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vitepress": "^1.6.4",
        "vitepress-plugin-mermaid": "^2.0.17"
    },
    "dependencies": {
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
        "@opentelemetry/instrumentation-express": "^0.68.0",
        "@opentelemetry/instrumentation-http": "^0.220.0",
        "@opentelemetry/instrumentation-mongoose": "^0.63.0",
        "@opentelemetry/instrumentation-redis": "^0.65.0",
        "@opentelemetry/sdk-node": "^0.220.0",
        "@opentelemetry/semantic-conventions": "^1.40.0",
        "amqplib": "^2.0.1",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "ejs": "^5.0.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.1",
        "helmet": "^8.1.0",
        "i18next": "^25.10.9",
        "jsonwebtoken": "^9.0.3",
        "mime-types": "^3.0.2",
        "mongodb": "^7.1.1",
        "mongoose": "^9.3.3",
        "multer": "^2.1.1",
        "nodemailer": "^9.0.3",
        "posthog-node": "^5.33.0",
        "prom-client": "^15.1.3",
        "puppeteer-core": "^24.40.0",
        "redis": "^5.12.1",
        "winston": "^3.19.0",
        "ws": "^8.20.0",
        "zod": "^4.3.6"
    }
}
