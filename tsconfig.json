{
  "compilerOptions": {
    "target": "ES6",
    "module": "es2020",
    "baseUrl": ".",
    "paths": {
      "@api/*": ["src/api/*"]
    },
    "strict": true,
    "composite": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "noPropertyAccessFromIndexSignature": false,
    "resolveJsonModule": true,
    "moduleResolution": "Node",
    "outDir": "./dist",
    "importsNotUsedAsValues": "remove",
    "ignoreDeprecations": "5.0",
    "types": ["node", "jest"],
    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ]
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src/*.ts",
    "src/**/*.ts",
    "src/**/*.json",
    "tests/**/*.test.ts"
  ]
}
