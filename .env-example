# Core
NODE_URL=http://localhost:3000/
NODE_ENV=development
NODE_PUBLIC_PATH=public # Storage

# API HTTP port (used by app.listen)
NODE_PORT=3000

# Websocket port
WEBSOCKET_PORT = 3001

# CORS allowed origins (comma-separated list)
NODE_CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:8080



# Mongo/Redis ports can now be used directly as fallbacks when URLs are not set.
NODE_MONGODB_PORT=27017
NODE_REDIS_PORT=6379
NODE_MONGODB_HOST=database
NODE_MONGODB_NAME=boilerplate-node-backend
NODE_REDIS_HOST=redis

# Database connection (preferred explicit URI; if omitted, HOST/PORT/NAME fallback is used)
NODE_DB_URI=mongodb://database:27017/boilerplate-node-backend

# Security
NODE_DEFAULT_LOCALE=en
NODE_FALLBACK_LOCALE=en
NODE_STATIC_MAXAGE=86400
NODE_ENABLE_CLUSTERING=1
NODE_CLUSTER_WORKERS=0
NODE_CLUSTER_CRASH_WINDOW_MS=60000
NODE_CLUSTER_CRASH_BACKOFF_BASE_MS=500
NODE_CLUSTER_CRASH_BACKOFF_MAX_MS=30000
NODE_CLUSTER_SHUTDOWN_TIMEOUT_MS=15000
NODE_GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000

# Redis cache
NODE_REDIS_URL=redis://redis:6379
NODE_REDIS_CACHE_ENABLED=1
NODE_REDIS_CACHE_PREFIX=boilerplate-node-backend

# JWT Authentication
# Access token: short-lived (e.g. 600 = 10 minutes)
NODE_TOKEN_ACCESS=your-access-token-secret-here
NODE_TOKEN_ACCESS_TIME=600

# Refresh token: long-lived (seconds)
NODE_TOKEN_REFRESH=your-refresh-token-secret-here
NODE_TOKEN_REFRESH_TIME_SHORT=604800      # 7 days
NODE_TOKEN_REFRESH_TIME_MEDIUM=2592000    # 30 days
NODE_TOKEN_REFRESH_TIME_LONG=31536000     # 1 year

# Token cleanup: interval (ms) between automatic expired-token sweeps (default: 3600000 = 1 hour)
NODE_TOKEN_CLEANUP_INTERVAL=3600000

# Email sender through nodemailer
NODE_SMTP_NAME=hostgator
NODE_SMTP_HOST=mail.guebbit.com
NODE_SMTP_PORT=465
NODE_SMTP_USER=noreply@guebbit.com
NODE_SMTP_SENDER="Guebbit <noreply@guebbit.com>"
NODE_SMTP_PASS=emailpassword


# Emails where feedbacks will be sent
NODE_CONTACT_NOTIFY_EMAIL=admin@guebbit.com

# Log verbosity level.
# Values: error | warn | info | http | verbose | debug | silly
# Default: 'info' in production, 'debug' in all other environments.
NODE_LOG_LEVEL=debug

# Service name tag written into every log entry.
# Useful when multiple services ship logs to the same aggregator (Loki, etc.).
NODE_SERVICE_NAME=api


# ─── RabbitMQ message queue (optional) ────────────────────────────────────────
# Leave unset to disable queue operations entirely.
# Full AMQP URI (preferred); if omitted, HOST/PORT/USER/PASS are used to build it.
#NODE_RABBITMQ_URL=******rabbitmq:5672
#NODE_RABBITMQ_HOST=rabbitmq
#NODE_RABBITMQ_PORT=5672
#NODE_RABBITMQ_USER=guest
#NODE_RABBITMQ_PASS=guest
# Set to 0 to explicitly disable even if URL is configured.
#NODE_RABBITMQ_ENABLED=1

# ─── Kafka (optional, AsyncAPI channels as topic names) ──────────────────────
# Leave brokers unset to disable Kafka integration.
#NODE_KAFKA_BROKERS=localhost:9092
#NODE_KAFKA_HOST=kafka
#NODE_KAFKA_PORT=9092
#NODE_KAFKA_CLIENT_ID=boilerplate-node-backend
#NODE_KAFKA_TOPIC_PREFIX=
#NODE_KAFKA_ENABLED=1
#NODE_KAFKA_AUDIT_GROUP=boilerplate-audit-group


# ─── OpenTelemetry tracing ──────────────────────────────────────────────────
# OTLP/HTTP endpoint of the Tempo (or any OTel-compatible) collector.
# Leave unset to disable trace export entirely. docker-compose sets this to http://tempo:4318
#OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318

# Optional: comma-separated key=value pairs added to every OTLP request.
#OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer secret,X-Tenant=default


# ─── PostHog product analytics (optional) ────────────────────────────────────
# Leave unset to disable all analytics emission.
#NODE_POSTHOG_API_KEY=phc_your_project_api_key_here
#NODE_POSTHOG_HOST=https://app.posthog.com