# Core
NODE_URL=http://localhost:3000/
NODE_ENV=development
# API HTTP port (used by app.listen)
NODE_PORT=3000
# Mongo/Redis ports can now be used directly as fallbacks when URLs are not set.
NODE_MONGODB_PORT=27017
NODE_REDIS_PORT=6379
NODE_MONGODB_HOST=database
NODE_MONGODB_NAME=boilerplate-node-backend
NODE_REDIS_HOST=redis

# Security
NODE_DEFAULT_LOCALE=en
NODE_FALLBACK_LOCALE=en
NODE_STATIC_MAXAGE=86400
NODE_ENABLE_CLUSTERING=1
NODE_CLUSTER_WORKERS=0
NODE_CLUSTER_CRASH_WINDOW_MS=60000
NODE_CLUSTER_CRASH_BACKOFF_BASE_MS=500
NODE_CLUSTER_CRASH_BACKOFF_MAX_MS=30000
NODE_CLUSTER_SHUTDOWN_TIMEOUT_MS=15000
NODE_GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000

# Redis cache
NODE_REDIS_URL=redis://redis:6379
NODE_REDIS_CACHE_ENABLED=1
NODE_REDIS_CACHE_PREFIX=boilerplate-node-backend

# Storage
NODE_PUBLIC_PATH=public


# Database connection (preferred explicit URI; if omitted, HOST/PORT/NAME fallback is used)
NODE_DB_URI=mongodb://database:27017/boilerplate-node-backend


# JWT Authentication
# Access token: short-lived (e.g. 600 = 10 minutes)
NODE_ACCESS_TOKEN_SECRET=your-access-token-secret-here
NODE_ACCESS_TOKEN_SECRET_TIME=600

# Refresh token: long-lived (seconds)
NODE_REFRESH_TOKEN_SECRET=your-refresh-token-secret-here
NODE_REFRESH_TOKEN_SECRET_TIME_SHORT=604800      # 7 days
NODE_REFRESH_TOKEN_SECRET_TIME_MEDIUM=2592000    # 30 days
NODE_REFRESH_TOKEN_SECRET_TIME_LONG=31536000     # 1 year

# Token cleanup: interval (ms) between automatic expired-token sweeps (default: 3600000 = 1 hour)
NODE_TOKEN_CLEANUP_INTERVAL=3600000


# Email
NODE_SMTP_NAME=hostgator
NODE_SMTP_HOST=mail.guebbit.com
NODE_SMTP_PORT=465
NODE_SMTP_USER=noreply@guebbit.com
NODE_SMTP_SENDER="Guebbit" <noreply@guebbit.com>
NODE_SMTP_PASS=emailpassword
