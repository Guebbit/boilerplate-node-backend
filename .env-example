# Core
NODE_URL=http://localhost:3000/
NODE_ENV=development
NODE_PORT=3000

# Security / Session
NODE_SESSION_SECRET=safesecret
NODE_DEFAULT_LOCALE=en
NODE_FALLBACK_LOCALE=en
NODE_STATIC_MAXAGE=86400
NODE_COOKIE_MAXAGE=2592000000
NODE_SESSION_MAXAGE=86400000
NODE_ENABLE_CLUSTERING=1

# Storage
NODE_PUBLIC_PATH=public


# Database connection (MySQL)
NODE_DB_HOST=localhost
NODE_DB_PORT=3306
NODE_DB_NAME=boilerplate_mysql
NODE_DB_USER=root
NODE_DB_PASS=rootpassword


# Email
NODE_SMTP_NAME=hostgator
NODE_SMTP_HOST=mail.guebbit.com
NODE_SMTP_PORT=465
NODE_SMTP_USER=noreply@guebbit.com
NODE_SMTP_SENDER="Guebbit" <noreply@guebbit.com>
NODE_SMTP_PASS=emailpassword

# Websocket
NODE_URL_WS=ws://localhost:3001/
NODE_PORT_WS=3001

# MVC Templating
NODE_SETTINGS_PAGINATION_PAGE_SIZE=3