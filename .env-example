# ============================================================
#  Boilerplate Node Backend — Environment Configuration
# ============================================================
# Copy this file to `.env` and adjust the values for your
# environment. Commented lines (`#`) are optional.
# ============================================================


# ============================================================
#  Core
# ============================================================

NODE_ENV=development
NODE_PUBLIC_PATH=public                           # static file storage directory
NODE_URL=http://localhost:3000/                   # base URL for outgoing links (e.g. email password-reset links)
NODE_PORT=3000                                    # API HTTP port (used by app.listen)
NODE_CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:8080  # CORS allowed origins (comma-separated)


# ============================================================
#  Database
# ============================================================

# MongoDB — preferred explicit URI; if omitted, HOST / PORT / NAME fallback is used
NODE_DB_URI=mongodb://database:27017/boilerplate-node-backend

# Fallback individual components (used when NODE_DB_URI is not set)
NODE_MONGODB_HOST=database
NODE_MONGODB_PORT=27017
NODE_MONGODB_NAME=boilerplate-node-backend


# ============================================================
#  Redis Cache
# ============================================================

NODE_REDIS_URL=redis://redis:6379
NODE_REDIS_HOST=redis
NODE_REDIS_PORT=6379
NODE_REDIS_CACHE_ENABLED=1
NODE_REDIS_CACHE_PREFIX=boilerplate-node-backend


# ============================================================
#  Security & Tokens
# ============================================================

NODE_DEFAULT_LOCALE=en
NODE_FALLBACK_LOCALE=en
NODE_DEFAULT_IMAGE_PRODUCT=https://placekitten.com/400/400
NODE_DEFAULT_IMAGE_USER=https://placekitten.com/600/600
NODE_RATE_LIMIT_WINDOW_MS=900000
NODE_RATE_LIMIT_MAX=100

# Access token — short-lived (value is in seconds; 600 = 10 minutes)
NODE_TOKEN_ACCESS=your-access-token-secret-here
NODE_TOKEN_ACCESS_TIME=600

# Refresh token — long-lived (seconds)
NODE_TOKEN_REFRESH=your-refresh-token-secret-here
NODE_TOKEN_REFRESH_TIME_SHORT=604800     # 7 days
NODE_TOKEN_REFRESH_TIME_MEDIUM=2592000   # 30 days
NODE_TOKEN_REFRESH_TIME_LONG=31536000    # 1 year

# Token cleanup is performed on-demand during refresh token operations.


# ============================================================
#  Clustering & Graceful Shutdown
# ============================================================

NODE_ENABLE_CLUSTERING=1
NODE_CLUSTER_WORKERS=0                            # 0 = auto (number of CPU cores)
NODE_CLUSTER_CRASH_WINDOW_MS=60000
NODE_CLUSTER_CRASH_BACKOFF_BASE_MS=500
NODE_CLUSTER_CRASH_BACKOFF_MAX_MS=30000
NODE_CLUSTER_SHUTDOWN_TIMEOUT_MS=15000
NODE_GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000


# ============================================================
#  Pagination
# ============================================================

# Default page size (used when the request omits pageSize)
#NODE_SETTINGS_PAGINATION_PAGE_SIZE=20


# ============================================================
#  Email (Nodemailer SMTP)
# ============================================================

NODE_SMTP_NAME=hostgator
NODE_SMTP_HOST=mail.guebbit.com
NODE_SMTP_PORT=465
NODE_SMTP_USER=noreply@guebbit.com
NODE_SMTP_SENDER="Guebbit <noreply@guebbit.com>"
NODE_SMTP_PASS=emailpassword

# Emails that will receive contact / feedback notifications
NODE_CONTACT_NOTIFY_EMAIL=admin@guebbit.com


# ============================================================
#  Logging
# ============================================================

# Log verbosity level.
# Values: error | warn | info | http | verbose | debug | silly
# Default: 'info' in production, 'debug' in all other environments.
NODE_LOG_LEVEL=debug

# Service name tag written into every log entry.
# Useful when multiple services ship logs to the same aggregator (Loki, etc.).
NODE_SERVICE_NAME=api


# ============================================================
#  RabbitMQ Message Queue  (optional)
# ============================================================
# Leave unset to disable queue operations entirely.
# Full AMQP URI is preferred; if omitted, HOST / PORT / USER / PASS are combined.

#NODE_RABBITMQ_URL=amqp://rabbitmq:5672
#NODE_RABBITMQ_HOST=rabbitmq
#NODE_RABBITMQ_PORT=5672
#NODE_RABBITMQ_USER=guest
#NODE_RABBITMQ_PASS=guest
#NODE_RABBITMQ_ENABLED=1                          # set to 0 to disable even when URL is configured


# ============================================================
#  OpenTelemetry Tracing  (optional)
# ============================================================
# OTLP/HTTP endpoint of the OTel Collector (fans out to Tempo, etc.).
# Leave unset to disable trace export entirely.
# docker-compose sets this to http://otel-collector:4318

#OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
#OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer secret,X-Tenant=default


# ============================================================
#  PostHog Product Analytics  (optional)
# ============================================================
# Leave unset to disable all analytics emission.

#NODE_POSTHOG_API_KEY=phc_your_project_api_key_here
#NODE_POSTHOG_HOST=https://app.posthog.com


# ============================================================
#  Frontend Observability  (self-hosted, for the paired frontend)
# ============================================================
# Alloy = browser-facing collector for the Grafana Faro Web SDK (errors, logs,
# web-vitals, frontend traces). The frontend posts to http://localhost:<ALLOY_FARO_PORT>/collect.
# Umami = self-hosted product analytics (pageviews + custom events), replaces PostHog cloud.

#ALLOY_FARO_PORT=12347                             # Faro receiver — the frontend posts telemetry here
#ALLOY_UI_PORT=12345                               # Alloy UI — inspect the ingest pipeline while debugging

# A Umami "website" is one tracked property (your frontend). Its id is the UUID the
# browser tracking script sends as data-website-id; events with an unknown id are dropped.
# Normally you'd create the website in the UI and copy the random id it generates — instead
# we seed a website with a FIXED id below, so the frontend can hardcode it with no manual step.
# All UMAMI_* below are optional: unset = the defaults shown here (a ready-to-use admin +
# website), exactly like a normal default install.

#UMAMI_PORT=8090                                   # Umami dashboard + tracking script origin
#UMAMI_APP_SECRET=change-me-please                 # random string used to hash session IDs
#UMAMI_ADMIN_USER=admin                            # admin login, stamped onto Umami on first boot
#UMAMI_ADMIN_PASSWORD=umami                        # admin password, stamped onto Umami on first boot
#UMAMI_WEBSITE_ID=00000000-0000-4000-8000-000000000001  # fixed id → the frontend's data-website-id
#UMAMI_WEBSITE_NAME=Frontend                       # display name of the auto-created website
#UMAMI_WEBSITE_DOMAIN=localhost                    # domain shown for the website in Umami
#UMAMI_DB_NAME=umami                               # Postgres database name for Umami
#UMAMI_DB_USER=umami                               # Postgres user for Umami
#UMAMI_DB_PASSWORD=umami                           # Postgres password for Umami

# Read by the API to report frontend-observability status in GET /observability/health
# (integrations.umami / integrations.faro). Set to the public URLs the frontend uses;
# leave unset and the health endpoint simply reports them as false.
#NODE_UMAMI_HOST=http://localhost:8090             # public Umami origin (surfaced in health)
#NODE_FARO_COLLECTOR_URL=http://localhost:12347/collect  # public Faro collector (surfaced in health)


# ============================================================
#  Promtail Log Collection
# ============================================================
# Pick one based on your container runtime.
# The base docker-compose.yml has no host log path — each runtime adds it via its override.

# Docker:
#COMPOSE_FILE=docker-compose.yml:docker-compose.docker.yml

# Podman (rootless — adjust path if running rootful):
#COMPOSE_FILE=docker-compose.yml:docker-compose.podman.yml
#PODMAN_CONTAINERS_PATH=/home/youruser/.local/share/containers/storage/overlay-containers


# ============================================================
#  Puppeteer / PDF Generation  (optional)
# ============================================================
# Path to the Chromium/Chrome binary used by puppeteer-core for PDF rendering.
# Defaults to /usr/bin/chromium-browser if unset.

#PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser


# ============================================================
# OTHERS
# ============================================================

# VitePress docs served by Nginx container
DOCS_PORT=4173
