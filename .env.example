# ============================================================
# Application
# ============================================================
NODE_ENV=development           # development | production | test
NODE_PORT=3000
NODE_HOST=0.0.0.0
NODE_URL=http://localhost:3000
NODE_SERVICE_NAME=api

NODE_ENABLE_CLUSTERING=false

# ============================================================
# Logging  (Phase 1)
# ============================================================
# Log level: error | warn | info | http | verbose | debug | silly
# Default: debug in dev, warn in prod
NODE_LOG_LEVEL=debug

# Optional Loki push gateway (leave blank to disable)
# NODE_LOKI_HOST=http://loki:3100

# ============================================================
# OpenTelemetry / Tracing  (Phase 3)
# ============================================================
# Master switch — defaults to false in dev, true in prod
OTEL_ENABLED=false

# Exporter: none | console | otlp
# Dev default  → none   (no noisy span objects in the terminal)
# Prod default → otlp   (sent to Tempo via OTLP/HTTP)
# OTEL_EXPORTER=none

# OTLP endpoint for Tempo (or any OTel collector)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318

# Set to "true" to dump raw span objects to stdout (debug only)
# DEBUG_TELEMETRY=false

# ============================================================
# Database
# ============================================================
# NODE_DB_URI=mongodb://localhost:27017/boilerplate

# ============================================================
# Auth / JWT
# ============================================================
# NODE_ACCESS_TOKEN_SECRET=change-me
# NODE_REFRESH_TOKEN_SECRET=change-me
# NODE_ACCESS_TOKEN_SECRET_TIME=15m
# NODE_REFRESH_TOKEN_SECRET_TIME_SHORT=1d
# NODE_REFRESH_TOKEN_SECRET_TIME_MEDIUM=7d
# NODE_REFRESH_TOKEN_SECRET_TIME_LONG=30d
